# =================================
# DUHOC NB - Environment Configuration
# =================================
# Copy this file to .env and fill in your values

# =================================
# APPLICATION SETTINGS
# =================================
NODE_ENV=development
PORT=5000
APP_NAME="Du Học Nhật Bản"

# =================================
# DATABASE CONFIGURATION
# =================================
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/duhocnb

# Alternative database config (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=duhocnb
DB_USER=postgres
DB_PASSWORD=your_password

# =================================
# SECURITY CONFIGURATION
# =================================
# JWT Secret - MUST be at least 32 characters long
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-characters-long

# JWT Expiration time (1d = 1 day, 7d = 7 days, etc.)
JWT_EXPIRES_IN=1d

# Bcrypt rounds (10-12 recommended for production)
BCRYPT_ROUNDS=12

# =================================
# CORS & API CONFIGURATION
# =================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# API Base URL
API_BASE_URL=http://localhost:5000/api

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# =================================
# RATE LIMITING
# =================================
# General API rate limit (requests per 15 minutes)
RATE_LIMIT_GENERAL=100

# Auth endpoints rate limit (requests per 15 minutes)
RATE_LIMIT_AUTH=5

# User management rate limit (requests per minute)
RATE_LIMIT_USER_MANAGEMENT=10

# =================================
# LOGGING
# =================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log directory
LOG_DIR=logs

# =================================
# EMAIL CONFIGURATION (Future)
# =================================
# SMTP settings for password reset emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Email templates
EMAIL_FROM="Du Học Nhật Bản <noreply@duhocnb.com>"

# =================================
# PRODUCTION SETTINGS
# =================================
# Set to true in production
PRODUCTION=false

# Session secret for production
SESSION_SECRET=your-session-secret-key-for-production